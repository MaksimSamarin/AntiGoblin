{
  "log": {
    "level": "debug",
    "output": "/opt/var/log/sing-box-test.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "bootstrap-dns",
        "address": "8.8.8.8",
        "detour": "direct"
      }
    ]
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "socks-test",
      "listen": "127.0.0.1",
      "listen_port": 10888,
      "users": [
        {
          "username": "<SOCKS_USERNAME>",
          "password": "<SOCKS_PASSWORD>"
        }
      ]
    },
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "sbtest0",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1500,
      "auto_route": false,
      "strict_route": false,
      "stack": "system"
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "vless-out",
      "server": "<VLESS_SERVER_HOST>",
      "server_port": <VLESS_SERVER_PORT>,
      "uuid": "<VLESS_UUID>",
      "flow": "xtls-rprx-vision",
      "network": "tcp",
      "packet_encoding": "",
      "tls": {
        "enabled": true,
        "server_name": "<REALITY_SERVER_NAME>",
        "utls": {
          "enabled": true,
          "fingerprint": "random"
        },
        "reality": {
          "enabled": true,
          "public_key": "<REALITY_PUBLIC_KEY>",
          "short_id": "<REALITY_SHORT_ID>"
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "vless-out"
  }
}
